rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read all profiles (needed for join lookups) but write only
    // their own. Role is NOT self-mutable past creation — escalation to
    // audiologist/admin requires a separate write from an existing admin.
    match /users/{uid} {
      function selfAssignableRoles() {
        return ['donor', 'recipient'];
      }
      function isCallerSelf() {
        return request.auth != null && request.auth.uid == uid;
      }
      function isElevated() {
        return request.auth != null &&
          request.auth.token.role in ['audiologist', 'admin'];
      }
      function userEditableFields() {
        return ['email', 'displayName'];
      }
      function roleUnchanged() {
        return request.resource.data.role == resource.data.role;
      }

      allow read: if request.auth != null;
      allow create: if isCallerSelf() &&
        request.resource.data.role in selfAssignableRoles();
      // Self may update profile fields but not role; admins may update role.
      allow update: if (isCallerSelf() && roleUnchanged() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(userEditableFields())) ||
        isElevated();
      allow delete: if isElevated();
    }

    // Scans: creator can read/write, audiologists + admins can read all
    match /scans/{scanId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.token.role in ['audiologist', 'admin']
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.token.role in ['audiologist', 'admin']
      );

      match /corrections/{correctionId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }

    // Incoming: scanner write-target. Any authed user can create (intake
    // volunteers, donors). Creator can read/update their own draft within a
    // field allow-list; audiologists/admins can read all and update freely
    // (they own the triage step that promotes into devices/).
    match /incoming/{incomingId} {
      // Field allow-list for non-role creator updates. Triage fields
      // (qaStatus, status, servicingCost, servicingNotes) are NOT in this
      // list — only audiologists/admins can set them.
      function creatorEditableFields() {
        return [
          'brand', 'model', 'type', 'year', 'serialLeft', 'serialRight',
          'batterySize', 'domeType', 'waxFilter', 'receiver',
          'programmingInterface', 'techLevel', 'gainRange', 'fittingRange',
          'remoteFT', 'appCompatible', 'auracast', 'chargerType',
          'accessories', 'condition', 'donorId', 'scanId', 'photos',
          'updatedAt'
        ];
      }
      function isCreator() {
        return resource.data.createdBy == request.auth.uid;
      }
      function isElevated() {
        return request.auth.token.role in ['audiologist', 'admin'];
      }
      function onlyAllowedFieldsChanged() {
        return request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(creatorEditableFields());
      }
      function createdByUnchanged() {
        return request.resource.data.createdBy == resource.data.createdBy;
      }

      allow read: if request.auth != null && (isCreator() || isElevated());
      allow create: if request.auth != null &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null && (
        isElevated() ||
        (isCreator() && createdByUnchanged() && onlyAllowedFieldsChanged())
      );
      // Creator may delete their own draft (volunteer fixing a mis-capture
      // or duplicate during intake); audiologists/admins may delete any.
      // The doc-delete cascades to the per-uid scans/{uid}/incoming/{id}/
      // Storage prefix client-side — see IncomingDeviceRepository.deleteIncoming.
      allow delete: if request.auth != null && (isCreator() || isElevated());
    }

    // Devices: post-triage register. Anyone authed can read; only
    // audiologists/admins write. Promotion happens via triage from incoming/,
    // and the trust-boundary invariant is enforced HERE at the backend — not
    // only in the client's promoteToDevice — so a direct client write can't
    // smuggle a flagged device into the curated register (Carnot, PR #87).
    match /devices/{deviceId} {
      function isElevated() {
        return request.auth != null &&
          request.auth.token.role in ['audiologist', 'admin'];
      }
      // No blocker keys on the RESULT = clean. A missing field is empty.
      function noBlockers() {
        return !('needsInputFields' in request.resource.data) ||
          request.resource.data.needsInputFields.size() == 0;
      }
      // A clinical field is UNRESOLVED when its value is missing, empty, or the
      // 'Unknown' volunteer-flag sentinel — the same notion the review screen's
      // _deSentinel + identityResolved use, enforced here at the boundary.
      function valueUnresolved(key) {
        return !(key in request.resource.data) ||
          !(request.resource.data[key] is string) ||
          request.resource.data[key] == '' ||
          request.resource.data[key] == 'Unknown';
      }
      function declaredBlocker(key) {
        return 'needsInputFields' in request.resource.data &&
          key in request.resource.data.needsInputFields;
      }
      // VALUE↔FLAG CONSISTENCY (Bypass A, cage-match PR #89): the gate trusts the
      // client's needsInputFields, so the client could claim a field resolved
      // (drop it from the set) while its value is still empty/sentinel — sneaking
      // an unresolved field into the curated register with no override + no audit.
      // Close it on request.resource.data ALONE (no cross-doc get): every clinical
      // field with an unresolved VALUE must be DECLARED as a blocker. Then
      // noBlockers() (nothing flagged) genuinely implies every clinical field
      // carries a real value, and the override path still describes what it skips.
      function valueFlagConsistent() {
        return (!valueUnresolved('brand') || declaredBlocker('brand')) &&
          (!valueUnresolved('model') || declaredBlocker('model')) &&
          (!valueUnresolved('type') || declaredBlocker('type')) &&
          (!valueUnresolved('tubing') || declaredBlocker('tubing')) &&
          (!valueUnresolved('powerSource') || declaredBlocker('powerSource')) &&
          (!valueUnresolved('batterySize') || declaredBlocker('batterySize')) &&
          (!valueUnresolved('colour') || declaredBlocker('colour'));
      }
      // A flagged result carries a qaOverride attributed to the caller — the
      // audit record can't be forged for someone else.
      function hasSelfAttributedOverride() {
        return 'qaOverride' in request.resource.data &&
          request.resource.data.qaOverride.overriddenBy == request.auth.uid;
      }
      // The blocker set is identical to what's already stored — an update that
      // edits OTHER fields (servicing, status) on an already-justified flagged
      // device, without re-crossing the intake boundary. Guarded so neither
      // side's missing field throws.
      function blockersUnchanged() {
        return ('needsInputFields' in request.resource.data)
            == ('needsInputFields' in resource.data) &&
          (!('needsInputFields' in request.resource.data) ||
            request.resource.data.needsInputFields == resource.data.needsInputFields);
      }
      // A self-attributed override that is FRESH this write (not the one already
      // stored). Changing the blocker set requires renewing the override, so an
      // elevated user can't expand blockers while reusing a stale override that
      // under-describes them (Carnot, PR #87 3rd pass).
      function overrideRenewed() {
        return hasSelfAttributedOverride() &&
          (!('qaOverride' in resource.data) ||
            request.resource.data.qaOverride != resource.data.qaOverride);
      }

      allow read: if request.auth != null;
      // Create crosses the trust boundary: the result must be value↔flag
      // consistent (no empty/sentinel clinical field left undeclared — Bypass A,
      // #89) AND clean OR carrying a self-attributed override.
      allow create: if isElevated() &&
        valueFlagConsistent() &&
        (noBlockers() || hasSelfAttributedOverride());
      // Update may NOT introduce/expand blockers except via a FRESH self-
      // attributed override (the side door, Carnot #87), and must stay value↔flag
      // consistent (#89). Editing other fields on an already-justified flagged
      // device (blocker set unchanged) is fine, and cleaning all blockers off is
      // fine — provided every now-clean field actually carries a value.
      allow update: if isElevated() &&
        valueFlagConsistent() &&
        (noBlockers() || blockersUnchanged() || overrideRenewed());
      allow delete: if isElevated();
    }

    // Catalog: read-only for all authed users, admin-writable
    match /hearingAidCatalog/{entryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.role == 'admin';
    }
  }
}
