{
  "name": "recycled-sound-rules-tests",
  "description": "Firestore + Storage security rules unit tests against the Firebase emulator",
  "private": true,
  "scripts": {
    "test": "mocha --timeout 30000 test/**/*.test.js",
    "test:emu": "firebase emulators:exec --only firestore,storage --project recycled-sound-app 'npm test'"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.0.0",
    "mocha": "^10.4.0"
  }
}
