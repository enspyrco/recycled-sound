rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Scan images: user can upload to their own folder
    match /scans/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Incoming device photos: scanner writes here after Confirm.
    // Any authed user can read (audiologists triage); creator writes.
    match /incoming/{incomingId}/photos/{photoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Device register photos: post-triage, audiologist-curated.
    match /devices/{deviceId}/photos/{photoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
