rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Elevated roles — audiologists and admins — get cross-tenant access
    // (they own triage + QA). Single source of truth for the role list,
    // mirroring `firestore.rules`' `isElevated()` so the two rule sets can't
    // drift. Declared once at the bucket scope and reused below instead of
    // being copy-pasted into every match block.
    function isElevated() {
      return request.auth != null
        && request.auth.token.role in ['audiologist', 'admin'];
    }

    // Scan-mode snapshots: transient stills the live scanner writes during a
    // detection session, namespaced by uid. Owner read/write; audiologists +
    // admins may read across users (triage review).
    //
    // READ is uid-gated, NOT just `request.auth != null` — the old rule let any
    // signed-in user read any other user's photos (a cross-user read leak).
    // WRITE is split into create/update vs delete so the owner can clean up
    // their own objects without the image-size/type predicate blocking a
    // delete (deletes carry no `request.resource`). DELETE also allows elevated
    // roles so an audiologist/admin can clean up a volunteer's mis-captured
    // device end-to-end (the Firestore incoming/ delete grants them the doc;
    // this grants them the photo blobs).
    match /scans/{userId}/{allPaths=**} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isElevated());
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && (request.auth.uid == userId || isElevated());
    }

    // Intake captures: the DURABLE photo bucket for the device-intake flow,
    // distinct from the transient scan-mode snapshots above. Canonical path is
    // `captures/{uid}/{deviceId}/{slot}.jpg` — uid is the OUTER security
    // boundary so the rule can gate on the path alone (no cross-service
    // firestore.get needed, unlike the legacy `incoming/{id}/photos/` block).
    // Same grants as the hardened scans block: owner read/write, elevated
    // (audiologist/admin) cross-user read for the triage register and elevated
    // delete for end-to-end cleanup.
    //
    // Captures holds TWO media kinds, each with its own size ceiling:
    //   * stills — the legacy 6-slot photo set (image/*, ≤ 10 MB), and
    //   * sweep clips — the in-app video-sweep protocol (video/*, ≤ 50 MB),
    //     uploaded as `captures/{uid}/{deviceId}/sweep_{ts}.mp4`.
    // A 10-15s 720p H.264 clip runs ~8-30 MB, so video gets a higher cap; the
    // image ceiling stays at 10 MB so a still upload can't smuggle 50 MB.
    //
    // **Extension ↔ content-type ↔ size are coupled** (not just content-type
    // paired with size). The `videos` field on the device doc must stay disjoint
    // from `photos` (a video URI in `photos` would 404 the thumbnail gallery),
    // and the gate is the only place that invariant can be ENFORCED on the wire.
    // So a `.mp4` path MUST be `video/*` and a non-`.mp4` path MUST be `image/*`:
    // this rejects a `video/mp4` smuggled to a `0.jpg`/`{slot}.jpg` photo path
    // (which would land in `photos`) AND an `image/*` written to a `sweep_*.mp4`
    // path. `request.resource.name` is the full object path string (e.g.
    // `captures/{uid}/{deviceId}/sweep_123.mp4`); `.matches` runs an ANCHORED
    // regex, so `.*[.]mp4` full-matches exactly the names ending in `.mp4`.
    match /captures/{userId}/{allPaths=**} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isElevated());
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && (
          (request.resource.name.matches('.*[.]mp4')
            && request.resource.contentType.matches('video/.*')
            && request.resource.size < 50 * 1024 * 1024)
          || (!request.resource.name.matches('.*[.]mp4')
            && request.resource.contentType.matches('image/.*')
            && request.resource.size < 10 * 1024 * 1024)
        );
      allow delete: if request.auth != null
        && (request.auth.uid == userId || isElevated());
    }

    // Incoming device photos (LEGACY): pre-migration intake photos written to
    // a uid-less path, doc-gated by the incoming/{id} doc's createdBy. New
    // intake photos go to `captures/{uid}/...` above; this block stays for
    // pre-migration objects still resolved via their stored gs:// URIs.
    //
    // The Firestore doc's createdBy gates write access — only the creator
    // (or an audiologist/admin) may upload to a given incoming/{id}/photos/
    // path. Cross-tenant photo overwrites would otherwise be possible since
    // the path itself carries no uid.
    match /incoming/{incomingId}/photos/{photoId} {
      function incomingDoc() {
        return firestore.get(
          /databases/(default)/documents/incoming/$(incomingId)
        );
      }

      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && (
          incomingDoc().data.createdBy == request.auth.uid
          || isElevated()
        );
    }

    // Device register photos: post-triage, audiologist-curated. Only
    // audiologists/admins may write — mirrors the Firestore devices/ rule.
    match /devices/{deviceId}/photos/{photoId} {
      allow read: if request.auth != null;
      allow write: if isElevated()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
