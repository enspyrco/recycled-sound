rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Elevated roles — audiologists and admins — get cross-tenant write
    // access (they own triage + QA). Single source of truth for the role
    // list, mirroring `firestore.rules`' `isElevated()` so the two rule
    // sets can't drift. Declared once at the bucket scope and reused below
    // instead of being copy-pasted into every match block.
    function isElevated() {
      return request.auth != null
        && request.auth.token.role in ['audiologist', 'admin'];
    }

    // Scan images: user can upload to their own folder
    match /scans/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Incoming device photos: scanner writes here after Confirm.
    // The Firestore doc's createdBy gates write access — only the creator
    // (or an audiologist/admin) may upload to a given incoming/{id}/photos/
    // path. Cross-tenant photo overwrites would otherwise be possible since
    // the path itself carries no uid.
    match /incoming/{incomingId}/photos/{photoId} {
      function incomingDoc() {
        return firestore.get(
          /databases/(default)/documents/incoming/$(incomingId)
        );
      }

      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && (
          incomingDoc().data.createdBy == request.auth.uid
          || isElevated()
        );
    }

    // Device register photos: post-triage, audiologist-curated. Only
    // audiologists/admins may write — mirrors the Firestore devices/ rule.
    match /devices/{deviceId}/photos/{photoId} {
      allow read: if request.auth != null;
      allow write: if isElevated()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
