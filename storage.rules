rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Scan + capture images: user owns their own prefix. Also the home for
    // in-app capture photos (scans/{uid}/incoming/{id}/…) — the incoming/
    // photos rule below relies on a cross-service firestore.get that does not
    // resolve in production, so capture writes here instead (pure-uid, and
    // stricter isolation than the doc-gated path).
    match /scans/{userId}/{allPaths=**} {
      // Owner-or-elevated read. A user reads their own prefix; audiologists
      // and admins may read any (the web triage shell renders capture photos
      // off another user's scans/{uid}/incoming path). Role comes from the
      // synced `role` custom claim — no cross-service firestore.get, which
      // does not resolve here. Plain authenticated read was a cross-user leak.
      allow read: if request.auth != null
        && (request.auth.uid == userId
          || request.auth.token.role in ['audiologist', 'admin']);
      // create/update carry a resource to validate (size + image type).
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      // delete has NO request.resource — gate on ownership only. Without this
      // separate grant, owner deletes are rejected (the size/contentType
      // predicates are null on a delete), orphaning objects.
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Incoming device photos: scanner writes here after Confirm.
    // The Firestore doc's createdBy gates write access — only the creator
    // (or an audiologist/admin) may upload to a given incoming/{id}/photos/
    // path. Cross-tenant photo overwrites would otherwise be possible since
    // the path itself carries no uid.
    match /incoming/{incomingId}/photos/{photoId} {
      function incomingDoc() {
        return firestore.get(
          /databases/(default)/documents/incoming/$(incomingId)
        );
      }
      function isElevated() {
        return request.auth.token.role in ['audiologist', 'admin'];
      }

      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && (
          incomingDoc().data.createdBy == request.auth.uid
          || isElevated()
        );
    }

    // Device register photos: post-triage, audiologist-curated. Only
    // audiologists/admins may write — mirrors the Firestore devices/ rule.
    match /devices/{deviceId}/photos/{photoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.role in ['audiologist', 'admin']
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
